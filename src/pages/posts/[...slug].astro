---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopBar from '../../components/TopBar.astro';
import TerminalPanel from '../../components/TerminalPanel.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', (p) => p.data.draft !== true);
  const sorted = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return sorted.map((post, idx) => ({
    params: { slug: post.id },
    props: {
      post,
      total: sorted.length,
      index: idx,
      prev: idx > 0 ? sorted[idx - 1] : null,
      next: idx < sorted.length - 1 ? sorted[idx + 1] : null,
    },
  }));
}

const { post, total, index, prev, next } = Astro.props;
const { Content } = await render(post);

const body = (post as unknown as { body?: string }).body ?? '';
const bytes = new TextEncoder().encode(body).length;
const lines = body.split('\n').length;
const fmBlock = `title:    "${post.data.title}"
date:     ${post.data.date.toISOString()}
author:   ${post.data.author ?? 'Leonardo Foo Haw Yang'}
tags:     ${JSON.stringify(post.data.tags ?? [])}
summary:  "${post.data.summary.replace(/"/g, '\\"')}"`;

const dateStr = post.data.date.toISOString().slice(0, 10);
const timeStr = post.data.date.toISOString().slice(11, 16);

const words = body.trim().split(/\s+/).filter(Boolean).length;
const readMin = Math.max(1, Math.round(words / 220));
---
<BaseLayout
  title={`${post.data.title} — Leonardo Foo`}
  description={post.data.summary}
  lang={post.data.lang}
>
  <TopBar active="writing" />

  <div class="v6-subhead">
    <a href="/posts/">← tail -f posts/</a>
    <span class="sep">/</span>
    <span>post {String(index + 1).padStart(2, '0')} of {String(total).padStart(2, '0')}</span>
  </div>

  <section class="v6-shell">
    <TerminalPanel
      title={`$ read_file content/posts/${post.id}.md`}
      meta={[`md · ${bytes} bytes`, `${lines} lines`, 'encoding: utf-8']}
    >
      <div style="padding: 18px 0 0;">
        <div class="v6-fm-card">
          <div class="v6-section-label">▸ frontmatter</div>
          <pre class="v6-fm-pre">{fmBlock}</pre>
        </div>

        <div class="v6-post-head">
          <h1>{post.data.title}</h1>
          <div class="v6-post-meta">
            <span>{dateStr} · {timeStr} utc+8</span>
            <span>·</span>
            <span>{readMin} min read</span>
            {post.data.tags && post.data.tags.length > 0 && (
              <>
                <span>·</span>
                <span>tag: <em>{post.data.tags.join(', ')}</em></span>
              </>
            )}
          </div>
        </div>

        <article class="v6-post-body">
          <Content />
        </article>

        <div class="v6-ask">
          <div class="v6-section-label">▸ ask about this post</div>
          <div class="v6-ask-row">
            <span class="v6-prompt">&gt;</span>
            <input
              type="text"
              placeholder="what theme does leonardo recommend? did he run into issues?"
              aria-label="question input"
              disabled
            />
            <button type="button" disabled>ask ↵</button>
          </div>
        </div>

        <nav class="v6-post-nav" aria-label="Post navigation">
          {prev ? (
            <a class="prev" href={`/posts/${prev.id}/`}>
              <span class="nv-label">← prev</span>
              <span class="nv-title">{prev.data.title}</span>
            </a>
          ) : (
            <span></span>
          )}
          {next ? (
            <a class="next" href={`/posts/${next.id}/`}>
              <span class="nv-label">next →</span>
              <span class="nv-title">{next.data.title}</span>
            </a>
          ) : (
            <span></span>
          )}
        </nav>
      </div>
    </TerminalPanel>
  </section>
</BaseLayout>
