---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopBar from '../../components/TopBar.astro';
import TerminalPanel from '../../components/TerminalPanel.astro';
import ToolCall from '../../components/ToolCall.astro';
import StreamItem from '../../components/StreamItem';

const rawPosts = await getCollection('posts', (p) => p.data.draft !== true);
const posts = rawPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const tagCounts = new Map<string, number>();
for (const p of posts) {
  for (const t of p.data.tags ?? []) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const tags = Array.from(tagCounts.entries()).sort((a, b) => b[1] - a[1]).slice(0, 8);

function countLines(raw: string): number {
  return raw.split('\n').length;
}

const entries = await Promise.all(
  posts.map(async (p, idx) => {
    const { rendered } = p;
    const body = (p as unknown as { body: string }).body ?? rendered?.html ?? '';
    const lines = countLines(body);
    const words = body.trim().split(/\s+/).filter(Boolean).length;
    const readMin = Math.max(1, Math.round(words / 220));
    const fm = `---
file:     ${p.id}.md
date:     ${p.data.date.toISOString().slice(0, 10)}
tags:     ${JSON.stringify(p.data.tags ?? [])}
read:     ${readMin} min
lines:    ${lines}
---`;
    return {
      id: p.id,
      date: p.data.date.toISOString().slice(0, 10),
      title: p.data.title,
      href: `/posts/${p.id}/`,
      readMin,
      words,
      frontmatterText: fm,
      summary: p.data.summary,
      fileName: `${p.id}.md`,
      initiallyOpen: idx === 0,
    };
  })
);
---
<BaseLayout
  title="Writing — Leonardo Foo"
  description="Essays, notes, and tutorials on AI, software engineering, and personal workflow."
>
  <TopBar active="writing" />

  <section class="v6-shell">
    <TerminalPanel
      title="$ tail -f ~/leonardo/content/posts/"
      meta={[`${posts.length} entries`, 'streaming: off', 'sort: date desc']}
    >
      <div style="padding: 18px 24px 22px;">
        <div style="margin-bottom: 18px;">
          <div class="v6-tool-line">
            <span>$ </span><span class="out">glob "content/posts/*.md" | sort -r</span>
          </div>
          <div class="v6-tools">
            <ToolCall name="glob" args='"content/posts/*.md"' result={`${posts.length} files`} />
            <ToolCall name="read_frontmatter" args="--all" result="parsed" />
          </div>
          <p style="color: var(--ink-3); margin: 8px 0 0; font-size: 13px;">
            Found <strong style="color: var(--ink);">{posts.length} posts</strong> in
            <em style="color: var(--accent); font-style: normal;">content/posts/</em>.
            Click any entry to preview its metadata.
          </p>
        </div>

        {tags.length > 0 && (
          <div class="v6-filters">
            <span class="v6-filters-label">filter:</span>
            <a class="v6-filter active" href="/posts/">all</a>
            {tags.map(([name]) => (
              <a class="v6-filter" href={`/tags/${name.toLowerCase().replace(/\s+/g, '-')}/`}>
                {name.toLowerCase()}
              </a>
            ))}
          </div>
        )}

        {entries.map((e) => (
          <StreamItem
            client:visible
            date={e.date}
            title={e.title}
            href={e.href}
            readMin={e.readMin}
            words={e.words}
            frontmatterText={e.frontmatterText}
            summary={e.summary}
            fileName={e.fileName}
            initiallyOpen={e.initiallyOpen}
          />
        ))}

        <div class="v6-stream-end">
          <span>end of stream · <span style="color: var(--ok);">●</span> watching for new posts</span>
          <span>
            <span style="color: var(--accent);">tip:</span>
            press <kbd>j</kbd>/<kbd>k</kbd> to navigate
          </span>
        </div>
      </div>
    </TerminalPanel>
  </section>
</BaseLayout>
