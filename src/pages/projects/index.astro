---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopBar from '../../components/TopBar.astro';
import TerminalPanel from '../../components/TerminalPanel.astro';
import ToolCall from '../../components/ToolCall.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const raw = await getCollection('projects', (p) => p.data.draft !== true);
const projects = raw.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const featuredCount = projects.filter((p) => p.data.featured).length;

const nowDate = new Date().toISOString().slice(0, 10);

const buildLog = projects.slice(0, 4).map((p) => ({
  t: p.data.date.toISOString().slice(0, 16).replace('T', ' '),
  msg: `${p.id} · ${p.data.summary.slice(0, 80)}`,
}));
---
<BaseLayout
  title="Projects — Leonardo Foo"
  description="Selected work across research, ML tooling, and infrastructure."
>
  <TopBar active="projects" />

  <section class="v6-shell">
    <TerminalPanel
      title="$ cat ~/leonardo/projects.json | jq ."
      meta={[
        `${projects.length} entries`,
        `featured: ${featuredCount}`,
        `last build: ${nowDate}`,
      ]}
    >
      <div style="padding: 20px 24px 22px;">
        <div class="v6-tools">
          <ToolCall name="read_file" args="~/projects.json" result={`parsed (${projects.length} entries)`} />
          <ToolCall name="gh_api" args="--repos" result="metadata fetched" />
        </div>

        <div class="v6-proj-intro">
          <span class="caret">▸ </span>
          Selected work across research, ML tooling, and infrastructure. Each entry is an object
          with <em>stack</em>, <em>status</em>, and <em>description</em>.
        </div>

        <div class="v6-proj-grid">
          {projects.map((p, i) => (
            <ProjectCard
              id={String(i + 1).padStart(3, '0')}
              year={p.data.date.getFullYear()}
              title={p.data.title}
              slug={p.id}
              status={p.data.status}
              featured={p.data.featured}
              desc={p.data.summary}
              stack={(p.data.technologies ?? []).map((t) => t.toLowerCase())}
              href={`/projects/${p.id}/`}
              projectUrl={p.data.project_url}
            />
          ))}
        </div>

        <div class="v6-buildlog">
          <div class="v6-section-label">▸ recent build log</div>
          {buildLog.map((e) => (
            <div class="v6-buildlog-row">
              <span class="t">{e.t}</span>
              <span class="ok">✓</span>
              <span>{e.msg}</span>
            </div>
          ))}
        </div>
      </div>
    </TerminalPanel>
  </section>
</BaseLayout>
